# Contact-form integrations. Both are optional; whichever is configured will fire.
# If both are unset, the form returns success with no side effect (useful in local dev).

# Resend — outgoing email
RESEND_API_KEY=
CONTACT_EMAIL=hello@drscherbakov.com
CONTACT_FROM_EMAIL=noreply@drscherbakov.com

# Telegram bot — direct ping for new requests
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Plausible Analytics — set to enable the snippet on production
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# Meta Pixel — set to enable the snippet on production
NEXT_PUBLIC_META_PIXEL_ID=

# Public messenger handles (used in every CTA on the site).
# Phone: international format, digits only, no "+". Usernames: no "@".
# Falls back to placeholders in src/lib/contact.ts if unset.
NEXT_PUBLIC_WHATSAPP_PHONE=
NEXT_PUBLIC_TELEGRAM_HANDLE=
NEXT_PUBLIC_INSTAGRAM_HANDLE=
